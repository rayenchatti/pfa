# VeritasLearn — Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ── Gemini API ────────────────────────────────────────────────
# The Gemini key lives in Supabase Secrets for production (never in this file).
# Set it with: supabase secrets set GEMINI_API_KEY=your_key
# Only needed locally if running edge functions via `supabase start`
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
